# SlateDesk API Konfiguration
# Kopiere diese Datei zu .env und füge deine API-Keys ein.
# Siehe API_SETUP.md für eine Schritt-für-Schritt-Anleitung.

# OpenWeatherMap API Key (kostenlos: https://openweathermap.org/api)
VITE_OPENWEATHERMAP_API_KEY=

# OpenWeatherMap Stadt (Standard: Zurich,CH)
VITE_WEATHER_CITY=Zurich,CH

# NewsAPI Key (kostenlos: https://newsapi.org/)
VITE_NEWSAPI_KEY=

# NewsAPI Land (Standard: ch)
VITE_NEWS_COUNTRY=ch
